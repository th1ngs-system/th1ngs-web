<div id="contactModal" class="c-modal-overlay" aria-hidden="true" onclick="if(event.target===this)closeContactModal()">
  <div class="c-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="contactModalLabel">
    <div class="c-modal-header">
      <h5 class="contact-modal-title" id="contactModalLabel">Get started with Th1ngs</h5>
      <button class="c-modal-close" onclick="closeContactModal()" aria-label="Close">&times;</button>
    </div>
    <div class="c-modal-body">
      <p class="contact-modal-sub">Leave your email and we'll reach out to set you up.</p>
      <form action="https://formspree.io/f/mqegqnrl" method="POST" class="contact-form">
        <div class="c-field">
          <label for="contactEmail" class="contact-label">Your email</label>
          <input type="email" name="email" id="contactEmail" class="contact-input" placeholder="you@example.com" required>
        </div>
        <div class="c-field">
          <label for="contactMessage" class="contact-label">Message <span class="optional-hint">(optional)</span></label>
          <textarea name="message" id="contactMessage" class="contact-input" rows="3" placeholder="Tell us what you want to manage…"></textarea>
        </div>
        <button type="submit" class="btn-contact-submit">Send <i class="bi bi-arrow-right"></i></button>
      </form>
    </div>
  </div>
</div>

<script>
  function openContactModal() {
    var m = document.getElementById('contactModal');
    m.classList.add('is-open');
    m.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeContactModal() {
    var m = document.getElementById('contactModal');
    m.classList.remove('is-open');
    m.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeContactModal();
  });
</script>
